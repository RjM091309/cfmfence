# Email API – copy to .env and fill in (do NOT put real passwords here)
PORT=2801
TO_EMAIL=your-receive@example.com
FROM_EMAIL=CFM Fence Website <no-reply@yourdomain.com>

# SMTP (e.g. Gmail, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# MySQL – for leads, visit tracking, etc.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=cfm_fence

# Base URL of your deployed site (used for admin links in emails)
APP_BASE_URL=https://cfmfencesolutions.com


# Secret key for approving reviews from email links
REVIEW_ADMIN_KEY=change-me-to-a-long-random-string
